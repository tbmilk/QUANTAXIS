# OpenCTP TTS 行情联调环境变量模板
# 用法:
#   set -a
#   source qapro-rs/examples/openctp_md_gateway.env.example
#   set +a
#   cargo run --manifest-path qapro-rs/Cargo.toml --example openctp_md_gateway --features openctp

# TTS 行情/交易前置
export OPENCTP_MD_FRONT="tcp://121.37.80.177:20004"
export OPENCTP_TD_FRONT="tcp://121.37.80.177:20002"

# CTP 账户
export OPENCTP_BROKER_ID="9999"
export OPENCTP_USER_ID=""
export OPENCTP_PASSWORD=""

# 柜台认证
# 普通 TTS 环境下可按券商/柜台要求填写，若不需要可留空
export OPENCTP_APP_ID=""
export OPENCTP_AUTH_CODE=""

# OpenCTP 动态库路径
# Linux 示例:
# export OPENCTP_MD_DYNLIB="/opt/openctp/thostmduserapi_se.so"
# export OPENCTP_TD_DYNLIB="/opt/openctp/thosttraderapi_se.so"
export OPENCTP_MD_DYNLIB=""
export OPENCTP_TD_DYNLIB=""

# 本地 flow 目录
export OPENCTP_FLOW_PATH="./.cache/openctp"

# 订阅合约，逗号分隔
export OPENCTP_INSTRUMENTS="ag2604,fu2605"
